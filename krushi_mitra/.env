# Krushi Mitra - Environment Variables (FREE TIER CONFIG)
# All services below have a generous free tier

# Google Gemini AI (1,500 requests/day FREE)
# Get key here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap (60 calls/minute FREE)
# Get key here: https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Data.gov.in - Agmarknet (FREE)
# Get key here: https://data.gov.in/user/register
DATA_GOV_API_KEY=your_data_gov_api_key_here
